{
  "manifest_version": 3,
  "name": "MediaForge",
  "version": "1.0.0",
  "description": "Professional YouTube downloader UI with queue, history, settings, and yt-dlp backend integration.",
  "permissions": [
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://127.0.0.1:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings.html",
  "icons": {
    "128": "icon.svg"
  },
  "action": {
    "default_title": "MediaForge",
    "default_icon": "icon.svg"
  }
}
